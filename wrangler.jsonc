{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dv-hub",
  "compatibility_date": "2026-04-01",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dv-hub-production",
      "database_id": "local-only"
    }
  ]
}
